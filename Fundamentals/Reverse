public class Main {

    public static void main(String[] args) {
        int num = 12345;
        int ans = reverse(num);
        System.out.println(ans);
    }

    public static int reverse(int n) {
        String str = "";
        int rem = 0;
        while(n>0){
            rem = n%10;
            str = str + rem;
//            System.out.println(str);
            n=n/10;
        }
        return Integer.parseInt(str.toString());
    }
}
